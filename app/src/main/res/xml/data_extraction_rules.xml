<?xml version="1.0" encoding="utf-8"?>
<!--
  data_extraction_rules.xml
  Controls cloud backup and device-to-device transfer on Android 12+.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="." />
        <exclude domain="database" path="vineos.db" />
        <exclude domain="database" path="vineos.db-shm" />
        <exclude domain="database" path="vineos.db-wal" />
        <exclude domain="file" path="instances/" />
        <exclude domain="file" path="roms/" />
    </cloud-backup>
    <device-transfer>
        <!-- Don't transfer VM data during device migrations -->
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
