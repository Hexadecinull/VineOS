root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_size = 4
max_line_length = 140

# Wildcard imports are standard in Compose (e.g. import androidx.compose.material3.*)
ktlint_standard_no-wildcard-imports = disabled

# @Composable functions use PascalCase by convention (same as class names)
ktlint_function_naming_ignore_when_annotated_with = Composable

# Backing properties (_foo / foo pattern) — allow private mutable state fields
ktlint_standard_backing-property-naming = disabled

# Trailing commas — required in multiline call/declaration sites
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true

# Blank line at start of class body — generated/tool code often includes one
ktlint_standard_no-blank-line-before-rbrace = disabled

# Multiline expression wrapping — let developers break lines where readable
ktlint_standard_multiline-expression-wrapping = disabled

# Braces — allow single-line if/else without braces in simple expressions
ktlint_standard_no-single-line-block-comment = disabled

[*.md]
trim_trailing_whitespace = false
